//! Terminal Emulator Widget — Displays the Orbit shell inside a GUI window.
//!
//! Maintains a text buffer (scrollback + current input line), renders text
//! onto the window's per-pixel surface, and handles keyboard input.

extern crate alloc;

use alloc::string::String;
use alloc::vec;
use alloc::vec::Vec;
use spin::Mutex;

use crate::msg::message::*;
use crate::wm::window::{self, WindowHandle};

// ---------------------------------------------------------------------------
// Constants
// ---------------------------------------------------------------------------

/// Font glyph width in pixels.
const FONT_W: u32 = 8;
/// Font glyph height in pixels.
const FONT_H: u32 = 16;

/// Maximum scrollback lines.
const MAX_SCROLLBACK: usize = 512;

/// Default text colour (light grey).
const COLOR_TEXT: u32 = 0xFFCCCCCC;
/// Prompt colour (green).
const COLOR_PROMPT: u32 = 0xFF50C878;
/// Cursor colour (white).
const COLOR_CURSOR: u32 = 0xFFFFFFFF;
/// Header colour (cyan).
const COLOR_HEADER: u32 = 0xFF00BFFF;
/// Muted colour for secondary text.
const COLOR_MUTED: u32 = 0xFF808080;
/// Error colour.
const COLOR_ERROR: u32 = 0xFFFF6B6B;

const PROMPT: &str = "orbit> ";

// ---------------------------------------------------------------------------
// Terminal state
// ---------------------------------------------------------------------------

/// A single line with optional colour override.
struct TermLine {
    text: String,
    color: u32,
}

impl TermLine {
    fn new(text: &str, color: u32) -> Self {
        Self { text: String::from(text), color }
    }
}

/// Per-terminal emulator state.
pub struct TerminalState {
    /// The window handle this terminal is bound to.
    pub handle: WindowHandle,
    /// Scrollback buffer of output lines.
    lines: Vec<TermLine>,
    /// Current input line (after the prompt).
    input: String,
    /// Cursor column within the input line.
    cursor: usize,
    /// Scroll offset (0 = bottom).
    scroll: usize,
    /// Whether shift is held (for uppercase).
    shift_held: bool,
    /// Command history.
    history: Vec<String>,
    /// History navigation index.
    history_idx: usize,
}

impl TerminalState {
    fn new(handle: WindowHandle) -> Self {
        let mut ts = Self {
            handle,
            lines: Vec::new(),
            input: String::new(),
            cursor: 0,
            scroll: 0,
            shift_held: false,
            history: Vec::new(),
            history_idx: 0,
        };
        // Welcome banner
        ts.lines.push(TermLine::new("AstryxOS Orbit Shell v0.1", COLOR_HEADER));
        ts.lines.push(TermLine::new("Type 'help' for a list of commands.", COLOR_MUTED));
        ts.lines.push(TermLine::new("", COLOR_TEXT));
        ts
    }
}

/// Global terminal state. Only one GUI terminal is supported for now.
static TERMINAL: Mutex<Option<TerminalState>> = Mutex::new(None);

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

/// Initialise the terminal emulator for the given window.
pub fn init(handle: WindowHandle) {
    *TERMINAL.lock() = Some(TerminalState::new(handle));
    render_to_surface();
}

/// Returns the handle of the terminal window, if initialised.
pub fn terminal_handle() -> Option<WindowHandle> {
    TERMINAL.lock().as_ref().map(|t| t.handle)
}

/// Handle a keyboard message directed at the terminal window.
/// Returns `true` if the message was consumed.
pub fn handle_key(msg: u32, wparam: u64, _lparam: u64) -> bool {
    let mut guard = TERMINAL.lock();
    let term = match guard.as_mut() {
        Some(t) => t,
        None => return false,
    };

    match msg {
        WM_KEYDOWN => {
            match wparam {
                VK_SHIFT => {
                    term.shift_held = true;
                    return true;
                }
                VK_RETURN => {
                    // Execute command
                    let cmd = term.input.clone();
                    // Add prompt + input as a line in scrollback
                    let line = alloc::format!("{}{}", PROMPT, cmd);
                    term.lines.push(TermLine::new(&line, COLOR_PROMPT));
                    term.input.clear();
                    term.cursor = 0;
                    if !cmd.is_empty() {
                        term.history.push(cmd.clone());
                        term.history_idx = term.history.len();
                    }
                    drop(guard);
                    execute_command(&cmd);
                    render_to_surface();
                    return true;
                }
                VK_BACK => {
                    if term.cursor > 0 {
                        term.cursor -= 1;
                        term.input.remove(term.cursor);
                    }
                }
                VK_DELETE => {
                    if term.cursor < term.input.len() {
                        term.input.remove(term.cursor);
                    }
                }
                VK_LEFT => {
                    if term.cursor > 0 {
                        term.cursor -= 1;
                    }
                }
                VK_RIGHT => {
                    if term.cursor < term.input.len() {
                        term.cursor += 1;
                    }
                }
                VK_HOME => {
                    term.cursor = 0;
                }
                VK_END => {
                    term.cursor = term.input.len();
                }
                VK_UP => {
                    // History: previous command
                    if term.history_idx > 0 {
                        term.history_idx -= 1;
                        term.input = term.history[term.history_idx].clone();
                        term.cursor = term.input.len();
                    }
                }
                VK_DOWN => {
                    // History: next command
                    if term.history_idx < term.history.len() {
                        term.history_idx += 1;
                        if term.history_idx < term.history.len() {
                            term.input = term.history[term.history_idx].clone();
                        } else {
                            term.input.clear();
                        }
                        term.cursor = term.input.len();
                    }
                }
                VK_ESCAPE => {
                    term.input.clear();
                    term.cursor = 0;
                }
                VK_PAGEUP => {
                    term.scroll = term.scroll.saturating_add(5);
                }
                VK_PAGEDOWN => {
                    term.scroll = term.scroll.saturating_sub(5);
                }
                _ => {
                    // Try to translate to a character.
                    if let Some(ch) = crate::msg::input::vk_to_char(wparam, term.shift_held) {
                        if ch >= ' ' && ch <= '~' {
                            term.input.insert(term.cursor, ch);
                            term.cursor += 1;
                        }
                    }
                }
            }
            drop(guard);
            render_to_surface();
            true
        }
        WM_KEYUP => {
            if wparam == VK_SHIFT {
                term.shift_held = false;
            }
            true
        }
        _ => false,
    }
}

// ---------------------------------------------------------------------------
// Command execution (minimal built-in shell)
// ---------------------------------------------------------------------------

fn execute_command(cmd: &str) {
    let parts: Vec<&str> = cmd.trim().splitn(2, ' ').collect();
    let command = parts.first().copied().unwrap_or("");
    let args = if parts.len() > 1 { parts[1] } else { "" };

    match command {
        "" => {}
        "help" => {
            push_line("Available commands:", COLOR_HEADER);
            push_line("  help         - Show this help", COLOR_TEXT);
            push_line("  clear / cls  - Clear the screen", COLOR_TEXT);
            push_line("  ver          - Show version info", COLOR_TEXT);
            push_line("  uname        - System information", COLOR_TEXT);
            push_line("  echo <text>  - Echo text", COLOR_TEXT);
            push_line("  ls [path]    - List directory", COLOR_TEXT);
            push_line("  cat <file>   - Show file contents", COLOR_TEXT);
            push_line("  date         - Show uptime ticks", COLOR_TEXT);
            push_line("  whoami       - Current user", COLOR_TEXT);
            push_line("  hostname     - Show hostname", COLOR_TEXT);
            push_line("  ps           - List processes", COLOR_TEXT);
            push_line("  free         - Memory info", COLOR_TEXT);
        }
        "clear" | "cls" => {
            let mut guard = TERMINAL.lock();
            if let Some(term) = guard.as_mut() {
                term.lines.clear();
                term.scroll = 0;
            }
        }
        "ver" | "version" => {
            push_line("AstryxOS Aether Kernel v0.1", COLOR_HEADER);
            push_line("Orbit Shell (GUI Terminal)", COLOR_TEXT);
        }
        "uname" | "uname -a" => {
            push_line("AstryxOS aether 0.1.0 x86_64 UEFI", COLOR_TEXT);
        }
        "echo" => {
            push_line(args, COLOR_TEXT);
        }
        "ls" => {
            let path = if args.is_empty() { "/" } else { args };
            match crate::vfs::readdir(path) {
                Ok(entries) => {
                    for (name, ftype) in entries {
                        let prefix = match ftype {
                            crate::vfs::FileType::Directory => "\u{1F4C1} ",
                            crate::vfs::FileType::RegularFile => "  ",
                            _ => "  ",
                        };
                        let line = alloc::format!("{}{}", prefix, name);
                        let color = match ftype {
                            crate::vfs::FileType::Directory => 0xFF5DADE2,  // blue
                            _ => COLOR_TEXT,
                        };
                        push_line(&line, color);
                    }
                }
                Err(e) => {
                    let msg = alloc::format!("ls: {}: {:?}", path, e);
                    push_line(&msg, COLOR_ERROR);
                }
            }
        }
        "cat" => {
            if args.is_empty() {
                push_line("cat: missing file operand", COLOR_ERROR);
            } else {
                match crate::vfs::read_file(args) {
                    Ok(data) => {
                        let text = core::str::from_utf8(&data).unwrap_or("<binary>");
                        for line in text.lines() {
                            push_line(line, COLOR_TEXT);
                        }
                    }
                    Err(e) => {
                        let msg = alloc::format!("cat: {}: {:?}", args, e);
                        push_line(&msg, COLOR_ERROR);
                    }
                }
            }
        }
        "date" => {
            let snap = crate::perf::snapshot();
            let msg = alloc::format!("Uptime: {} ticks (~{} seconds)", snap.uptime_ticks, snap.uptime_seconds);
            push_line(&msg, COLOR_TEXT);
        }
        "whoami" => {
            push_line("root", COLOR_TEXT);
        }
        "hostname" => {
            push_line("astryx", COLOR_TEXT);
        }
        "ps" => {
            push_line("  PID  NAME           STATE", COLOR_HEADER);
            push_line("    0  kernel         running", COLOR_TEXT);
            push_line("    1  ascension      running", COLOR_TEXT);
            push_line("    2  orbit          running", COLOR_TEXT);
        }
        "free" => {
            push_line("Memory usage:", COLOR_HEADER);
            let (total, used, free) = crate::mm::heap::stats();
            let msg = alloc::format!("  Heap:  {} used / {} total ({} free)", used, total, free);
            push_line(&msg, COLOR_TEXT);
        }
        _ => {
            let msg = alloc::format!("{}: command not found", command);
            push_line(&msg, COLOR_ERROR);
        }
    }
}

/// Push a line into the terminal scrollback buffer.
fn push_line(text: &str, color: u32) {
    let mut guard = TERMINAL.lock();
    if let Some(term) = guard.as_mut() {
        term.lines.push(TermLine::new(text, color));
        // Trim scrollback
        while term.lines.len() > MAX_SCROLLBACK {
            term.lines.remove(0);
        }
    }
}

// ---------------------------------------------------------------------------
// Surface rendering
// ---------------------------------------------------------------------------

/// Re-render the terminal text onto the bound window's surface.
pub fn render_to_surface() {
    let mut guard = TERMINAL.lock();
    let term = match guard.as_mut() {
        Some(t) => t,
        None => return,
    };

    let handle = term.handle;

    // Get client dimensions.
    let (cw, ch) = match window::with_window(handle, |w| (w.client_width, w.client_height)) {
        Some(dims) => dims,
        None => return,
    };

    if cw == 0 || ch == 0 {
        return;
    }

    let cols = (cw / FONT_W) as usize;
    let rows = (ch / FONT_H) as usize;
    if rows == 0 || cols == 0 {
        return;
    }

    // Build the surface locally.
    let bg: u32 = 0xFF0C0C0C; // very dark background for terminal
    let size = (cw as usize) * (ch as usize);
    let mut surface = vec![bg; size];
    let stride = cw;

    // Visible rows: last `rows - 1` lines of scrollback + prompt row at bottom.
    let prompt_row = rows - 1;
    let display_rows = rows - 1;

    // Determine which lines to show.
    let total_lines = term.lines.len();
    let scroll = term.scroll.min(total_lines.saturating_sub(display_rows));
    let end = total_lines.saturating_sub(scroll);
    let start = end.saturating_sub(display_rows);

    // Draw scrollback lines.
    for (i, line_idx) in (start..end).enumerate() {
        let tl = &term.lines[line_idx];
        draw_text_on_surface(
            &mut surface,
            stride,
            2,
            (i as u32 * FONT_H + 2) as i32,
            &tl.text,
            tl.color,
            cols,
        );
    }

    // Draw prompt + input line at the bottom.
    let py = (prompt_row as u32 * FONT_H + 2) as i32;
    draw_text_on_surface(&mut surface, stride, 2, py, PROMPT, COLOR_PROMPT, cols);
    let input_x = 2 + (PROMPT.len() as i32) * FONT_W as i32;
    draw_text_on_surface(&mut surface, stride, input_x, py, &term.input, COLOR_TEXT, cols - PROMPT.len());

    // Draw cursor (block cursor).
    let cursor_x = input_x + (term.cursor as i32) * FONT_W as i32;
    draw_cursor_block(&mut surface, stride, cursor_x, py, COLOR_CURSOR);

    // Write surface to the window.
    drop(guard);
    window::with_window_mut(handle, |w| {
        w.surface = surface;
    });
}

/// Draw a text string onto a pixel surface, clamped to `max_chars`.
fn draw_text_on_surface(
    buf: &mut [u32],
    stride: u32,
    x: i32,
    y: i32,
    text: &str,
    color: u32,
    max_chars: usize,
) {
    let mut cx = x;
    for (i, ch) in text.chars().enumerate() {
        if i >= max_chars {
            break;
        }
        if ch == '\n' || ch == '\r' {
            continue;
        }
        draw_char_on_surface(buf, stride, cx, y, ch, color);
        cx += FONT_W as i32;
    }
}

/// Draw a single 8×16 glyph onto a pixel buffer.
fn draw_char_on_surface(buf: &mut [u32], stride: u32, x: i32, y: i32, ch: char, color: u32) {
    let c = ch as u32;
    if c < 0x20 || c > 0x7E {
        return;
    }
    let glyph_offset = ((c - 0x20) as usize) * 16;
    let font = &crate::gui::compositor::VGA_FONT_8X16;

    for row in 0..16i32 {
        let py = y + row;
        if py < 0 {
            continue;
        }
        let byte = font[glyph_offset + row as usize];
        for col in 0..8i32 {
            let px = x + col;
            if px < 0 || px >= stride as i32 {
                continue;
            }
            if (byte >> (7 - col)) & 1 != 0 {
                let idx = py as usize * stride as usize + px as usize;
                if idx < buf.len() {
                    buf[idx] = color;
                }
            }
        }
    }
}

/// Draw a blinking block cursor.
fn draw_cursor_block(buf: &mut [u32], stride: u32, x: i32, y: i32, color: u32) {
    // Draw a filled rectangle FONT_W × FONT_H with transparency.
    for row in 0..FONT_H as i32 {
        let py = y + row;
        if py < 0 {
            continue;
        }
        for col in 0..2i32 {
            let px = x + col;
            if px < 0 || px >= stride as i32 {
                continue;
            }
            let idx = py as usize * stride as usize + px as usize;
            if idx < buf.len() {
                buf[idx] = color;
            }
        }
    }
}
